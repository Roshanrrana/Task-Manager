# Optional — only needed when the UI is NOT served by Vite dev (e.g. Vercel / Netlify production build).
# Must point at your deployed backend’s /api prefix (no trailing slash after /api).
#
# Example (Render):
# VITE_API_URL=https://taskpilot-api-xxxx.onrender.com/api
#
# Example (Railway):
# VITE_API_URL=https://taskpilot-production.up.railway.app/api
#
# Local development: leave unset or comment out — requests use /api and Vite proxies to localhost:5000.

# VITE_API_URL=
