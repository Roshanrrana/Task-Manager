# Copy this file to .env and adjust values.

# --- Local development (Docker Mongo from repo root: docker compose up -d) ---
MONGO_URI=mongodb://127.0.0.1:27017/taskflow

# --- Or MongoDB Atlas (replace with your connection string) ---
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/taskflow?retryWrites=true&w=majority
#
# The backend also accepts MONGODB_URI or MONGO_URL if your host/plugin provides one.

JWT_SECRET=change_this_to_a_long_random_string_for_production
PORT=5000

# --- Production CORS (comma-separated exact origins of your deployed UI, no trailing slash) ---
# Example: https://taskflow.vercel.app,https://www.yourdomain.com
# Leave unset for local dev (all origins allowed).
# CLIENT_ORIGINS=
